 {:id :openai
  :name "OpenAI"
  :description "Connect Xia to OpenAI models."
  :category :cloud
  :base-url "https://api.openai.com/v1"
  :model-suggestion "gpt-5"
  :access-modes [{:id :account
                  :label "Web account session"
                  :description "Use a connected ChatGPT account in Xia's managed browser."
                  :credential-sources [:browser-session]
                  :default? true}
                 {:id :api
                  :label "API credential"
                  :description "Use metered API access with an API key."
                  :credential-sources [:api-key]}]
  :account-connector :openai-browser
  :account-url "https://platform.openai.com/"
  :api-key-url "https://platform.openai.com/api-keys"
  :docs-url "https://help.openai.com/en/articles/4936850-where-do-i-find-my-api-key"
  :sign-in-options [:google :microsoft :apple]
  :notes "For personal use, start with your ChatGPT subscription account. Xia opens a dedicated managed browser for sign-in, then reuses that saved web account session for later requests. API access is billed separately."}
