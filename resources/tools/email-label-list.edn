;; List Gmail labels.
;; Import with: /import-tool resources/tools/email-label-list.edn

{:id          :email-label-list
 :name        "email-label-list"
 :description "List Gmail labels so you can inspect built-in labels and discover custom label ids before using email-update."
 :tags        #{:email :gmail :labels :communication}
 :approval    :session
 :parameters  {"type"       "object"
               "properties" {"service_id" {"type"        "string"
                                           "description" "Optional Gmail service id if you have more than one configured"}}}
 :handler     "(fn [args]
                 (xia.email/list-labels
                   :service-id (get args \"service_id\")))"}
