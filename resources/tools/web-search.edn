;; Search the web and return structured results.
;; Import with: /import-tool resources/tools/web-search.edn

{:id          :web-search
 :name        "web-search"
 :description "Search the web for information. Returns a list of results with titles, URLs, and snippets. Use this when you need to find web pages about a topic."
 :execution-mode :parallel-safe
 :parameters  {"type"       "object"
               "properties" {"query"       {"type"        "string"
                                            "description" "The search query"}
                             "max_results" {"type"        "integer"
                                            "description" "Max number of results to return (default 5)"}}
               "required"   ["query"]}
 :handler     "(fn [args]
                 (xia.web/search-web (get args \"query\")
                                     :max-results (or (get args \"max_results\") 5)))"}
