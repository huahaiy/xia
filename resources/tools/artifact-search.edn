;; Search generated artifacts across current and prior sessions.
;; Import with: /import-tool resources/tools/artifact-search.edn

{:id             :artifact-search
 :name           "artifact-search"
 :description    "Search generated artifacts across current and prior sessions by name, title, or text content. Use this when resuming earlier work or when the relevant artifact may not belong to the active chat session."
 :tags           #{:artifact :output :search :retrieval}
 :execution-mode :parallel-safe
 :parameters     {"type"       "object"
                  "properties" {"query" {"type"        "string"
                                         "description" "What to search for in stored generated artifacts."}
                                "top"   {"type"        "integer"
                                         "description" "Maximum number of matching artifacts to return (default 5)."}}
                  "required"   ["query"]}
 :handler        "(fn [args]
                    (xia.artifact/search-visible-artifacts (get args \"query\")
                                                           :top (or (get args \"top\") 5)))"}
