;; Send a message to another Xia instance through a configured peer service.
;; Import with: /import-tool resources/tools/peer-chat.edn

{:id          :peer-chat
 :name        "peer-chat"
 :description "Send a message to another Xia instance through a configured peer service. Use peer-list first if you do not know the peer service id. Returns the peer session id so later calls can continue the same remote conversation."
 :tags        #{:peer :service :instance :multi-instance :delegation :communication}
 :approval    :session
 :parameters  {"type"       "object"
               "properties" {"service_id" {"type"        "string"
                                           "description" "The peer service id from peer-list or admin service configuration."}
                             "message"    {"type"        "string"
                                           "description" "Message to send to the peer Xia instance."}
                             "session_id" {"type"        "string"
                                           "description" "Optional peer session id returned by a previous peer-chat call."}
                             "timeout_ms" {"type"        "integer"
                                           "description" "Optional request timeout in milliseconds for waiting on the peer response."}}
               "required"   ["service_id" "message"]}
 :handler     "(fn [args]
                 (xia.peer/chat
                   (get args \"service_id\")
                   (get args \"message\")
                   :session-id (get args \"session_id\")
                   :timeout-ms (get args \"timeout_ms\")))"}
