;; Delete an existing draft.
;; Import with: /import-tool resources/tools/email-draft-delete.edn

{:id          :email-draft-delete
 :name        "email-draft-delete"
 :description "Delete an existing draft by id."
 :tags        #{:email :draft :delete :communication}
 :approval    :auto
 :parameters  {"type"       "object"
               "properties" {"draft_id" {"type"        "string"
                                         "description" "Draft id to delete"}
                             "service_id" {"type"        "string"
                                           "description" "Optional email service id if you have more than one configured"}}
               "required"   ["draft_id"]}
 :handler     "(fn [args]
                 (xia.email/delete-draft
                   (get args \"draft_id\")
                   :service-id (get args \"service_id\")))"}
