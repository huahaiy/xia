;; List generated artifacts across current and recent sessions.
;; Import with: /import-tool resources/tools/artifact-list.edn

{:id             :artifact-list
 :name           "artifact-list"
 :description    "List recently updated artifacts across current and prior sessions so you can resume earlier work without forcing the user to restate context."
 :tags           #{:artifact :output :list :retrieval}
 :execution-mode :parallel-safe
 :parameters     {"type"       "object"
                  "properties" {"top" {"type"        "integer"
                                        "description" "Maximum number of artifacts to return (default 20)."}}
                  "required"   []}
 :handler        "(fn [args]
                    (mapv #(dissoc % :text :sha256 :meta)
                          (xia.artifact/list-visible-artifacts :top (or (get args \"top\") 20))))"}
