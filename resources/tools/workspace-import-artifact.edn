;; Import a shared workspace item into the current session as an artifact.
;; Import with: /import-tool resources/tools/workspace-import-artifact.edn

{:id          :workspace-import-artifact
 :name        "workspace-import-artifact"
 :description "Import a shared workspace item into the current session as an artifact so Xia can continue working with it locally."
 :tags        #{:workspace :shared :collaboration :artifact :import}
 :approval    :session
 :parameters  {"type"       "object"
               "properties" {"item_id"      {"type"        "string"
                                             "description" "Workspace item id returned by workspace-list."}
                             "workspace_id" {"type"        "string"
                                             "description" "Optional shared workspace id. Defaults to `default`."}
                             "name"         {"type"        "string"
                                             "description" "Optional imported artifact filename override."}
                             "title"        {"type"        "string"
                                             "description" "Optional imported artifact title override."}}
               "required"   ["item_id"]}
 :handler     "(fn [args]
                 (dissoc (xia.workspace/import-item-as-artifact!
                           (get args \"item_id\")
                           :workspace-id (get args \"workspace_id\")
                           :name (get args \"name\")
                           :title (get args \"title\"))
                         :sha256 :meta :blob-id :blob-codec :compressed-size-bytes))"}
