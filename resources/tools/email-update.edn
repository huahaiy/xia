;; Update message state on the configured email backend.
;; Import with: /import-tool resources/tools/email-update.edn

{:id          :email-update
 :name        "email-update"
 :description "Update message state for a selected message id. Supports archive or unarchive, mark read or unread, and add or remove labels or categories depending on the backend."
 :tags        #{:email :labels :archive :communication}
 :approval    :auto
 :parameters  {"type"       "object"
               "properties" {"message_id"    {"type"        "string"
                                              "description" "Message id whose state should be updated"}
                             "archive"       {"type"        "boolean"
                                              "description" "When true archive the thread by removing INBOX. When false, restore the thread to INBOX."}
                             "read"          {"type"        "boolean"
                                              "description" "When true mark the thread read. When false, mark the thread unread."}
                             "add_labels"    {"type"        "array"
                                              "description" "Optional label ids or category names to add"
                                              "items"       {"type" "string"}}
                             "remove_labels" {"type"        "array"
                                              "description" "Optional label ids or category names to remove"
                                              "items"       {"type" "string"}}
                             "service_id"    {"type"        "string"
                                              "description" "Optional email service id if you have more than one configured"}}
               "required"   ["message_id"]}
 :handler     "(fn [args]
                 (xia.email/update-message
                   (get args \"message_id\")
                   :archive? (when (contains? args \"archive\")
                               (boolean (get args \"archive\")))
                   :read? (when (contains? args \"read\")
                            (boolean (get args \"read\")))
                   :add-labels (get args \"add_labels\")
                   :remove-labels (get args \"remove_labels\")
                   :service-id (get args \"service_id\")))"}
