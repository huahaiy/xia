#!/bin/bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"

if [ -n "${GRAALVM_HOME:-}" ]; then
  export JAVA_HOME="$GRAALVM_HOME"
  export PATH="$GRAALVM_HOME/bin:$PATH"
elif ! command -v native-image >/dev/null 2>&1; then
  echo "Please set GRAALVM_HOME or ensure native-image is on PATH"
  exit 1
fi

mkdir -p "$ROOT_DIR/target/native-test-tmp/.tmp" "$ROOT_DIR/target/native-test-image"

cd "$ROOT_DIR"

lein with-profile -dev,+native-test uberjar

NATIVE_IMAGE_HEAP="${XIA_NATIVE_IMAGE_HEAP:-10g}"
NATIVE_IMAGE_FLAGS=(
  --future-defaults=all
  -H:+AddAllCharsets
  -Djava.awt.headless=true
  "-J-Xmx${NATIVE_IMAGE_HEAP}"
)

if [ -n "${XIA_NATIVE_PGO_PROFILE:-}" ]; then
  NATIVE_IMAGE_FLAGS+=("--pgo=${XIA_NATIVE_PGO_PROFILE}")
fi

if [ "${XIA_NATIVE_MARCH_NATIVE:-0}" = "1" ]; then
  NATIVE_IMAGE_FLAGS+=("-H:CCompilerOption=-march=native")
fi

env TMPDIR="$ROOT_DIR/target/native-test-tmp/.tmp" \
  native-image \
  --verbose \
  -H:TempDirectory=target/native-test-tmp \
  -H:Path=target/native-test-image \
  "${NATIVE_IMAGE_FLAGS[@]}" \
  -jar target/xia-tests.jar \
  -H:Name=xia-tests

exec "$ROOT_DIR/target/native-test-image/xia-tests" "$@"
