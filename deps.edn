{:paths ["src" "resources"]

 :deps
 {org.clojure/clojure       {:mvn/version "1.12.0"}
  datalevin/datalevin        {:mvn/version "0.10.7"}
  org.clojure/tools.cli      {:mvn/version "1.1.230"}

  ;; HTTP client for LLM API calls
  hato/hato                  {:mvn/version "1.0.0"}

  ;; JSON
  com.cnuernber/charred      {:mvn/version "1.034"}

  ;; SCI — Clojure interpreter that works in GraalVM native-image
  org.babashka/sci            {:mvn/version "0.8.43"}

  ;; HTTP/WebSocket server
  http-kit/http-kit           {:mvn/version "2.8.0"}

  ;; Logging
  org.clojure/tools.logging  {:mvn/version "1.3.0"}
  ch.qos.logback/logback-classic {:mvn/version "1.5.6"}}

 :aliases
 {:dev
  {:extra-paths ["test"]
   :extra-deps  {io.github.cognitect-labs/test-runner
                 {:git/tag "v0.5.1" :git/sha "dfb30dd"}}}

  :test
  {:main-opts ["-m" "cognitect.test-runner"]
   :exec-fn   cognitect.test-runner.api/test}

  :native
  {:extra-deps {org.graalvm.nativeimage/svm {:mvn/version "24.1.1"}}
   :main-opts  ["-m" "xia.core"]}

  :build
  {:deps  {io.github.clojure/tools.build {:mvn/version "0.10.5"}}
   :ns-default build}

  :uberjar
  {:replace-deps {com.github.seancorfield/depstar {:mvn/version "2.1.303"}}
   :exec-fn      hf.depstar/uberjar
   :exec-args    {:jar "target/xia.jar"
                  :aot true
                  :main-class "xia.core"}}}}
