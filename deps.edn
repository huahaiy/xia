{:paths ["src" "resources"]

  :deps
  {org.clojure/clojure       {:mvn/version "1.12.4"}
  integrant/integrant       {:mvn/version "0.13.1"}
  org.datalevin/datalevin-embedded {:mvn/version "0.10.13"}
  org.clojure/tools.cli      {:mvn/version "1.4.256"}

  ;; HTTP client for LLM API calls
  hato/hato                  {:mvn/version "1.0.0"}

  ;; JSON
  com.cnuernber/charred      {:mvn/version "1.038"}

  ;; SCI — Clojure interpreter that works in GraalVM native-image
  org.babashka/sci            {:mvn/version "0.12.51"}

  ;; HTML parsing (GraalVM native-image compatible)
  org.jsoup/jsoup              {:mvn/version "1.22.1"}

  ;; PDF text extraction for local documents.
  ;; Keep the classpath lean: we only use text extraction, not crypto/XML extras.
  com.github.librepdf/openpdf {:mvn/version "3.0.0"
                               :exclusions [com.ibm.icu/icu4j
                                            org.bouncycastle/bcprov-jdk18on
                                            org.bouncycastle/bcpkix-jdk18on
                                            org.apache.xmlgraphics/fop]}

  ;; Real browser backend for modern web apps
  com.microsoft.playwright/playwright {:mvn/version "1.52.0"}

  ;; HTTP/WebSocket server
  http-kit/http-kit           {:mvn/version "2.8.1"}
  ring/ring-core             {:mvn/version "1.12.2"}

  ;; Logging
  com.taoensso/timbre        {:mvn/version "6.5.0"}}

 :aliases
 {:dev
  {:extra-paths ["test" "dev" "dev-resources"]
   :main-opts  ["-i" "dev/compiler_warnings.clj"]
   :extra-deps  {io.github.cognitect-labs/test-runner
                 {:git/tag "v0.5.1" :git/sha "dfb30dd"}
                 nrepl/nrepl
                 {:mvn/version "1.3.1"}
                 org.clojure/tools.namespace
                 {:mvn/version "1.5.1"}}}

  :repl
  {:main-opts ["-r"]}

  :test
  {:extra-paths ["test" "dev" "dev-resources"]
   :extra-deps  {io.github.cognitect-labs/test-runner
                 {:git/tag "v0.5.1" :git/sha "dfb30dd"}
                 nrepl/nrepl
                 {:mvn/version "1.3.1"}
                 org.clojure/tools.namespace
                 {:mvn/version "1.5.1"}}
   :main-opts ["-m" "xia.test-runner"]
   :exec-fn   cognitect.test-runner.api/test}

  :embedding-eval
  {:extra-paths ["dev" "dev-resources"]
   :main-opts ["-i" "dev/compiler_warnings.clj"
               "-m" "xia.embedding-eval"]}

  :summarization-eval
  {:extra-paths ["dev" "dev-resources"]
   :main-opts ["-i" "dev/compiler_warnings.clj"
               "-m" "xia.summarization-eval"]}

  :native
  {:extra-deps {org.graalvm.nativeimage/svm {:mvn/version "25.0.2"}}
   :main-opts  ["-m" "xia.core"]}

  :build
  {:deps  {io.github.clojure/tools.build {:mvn/version "0.10.12"}}
   :ns-default build}

  :uberjar
  {:replace-deps {com.github.seancorfield/depstar {:mvn/version "2.1.303"}}
   :exec-fn      hf.depstar/uberjar
   :exec-args    {:jar "target/xia.jar"
                  :aot true
                  :main-class "xia.core"}}}}
